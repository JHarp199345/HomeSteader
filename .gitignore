# Local records and generated state must never be committed.
data/*
!data/.gitkeep
inbox/*
!inbox/.gitkeep
ai_staging/*
!ai_staging/.gitkeep

# Python artifacts
__pycache__/
*.py[cod]
.venv/
*.egg-info/
node_modules

# Large local-only fictional training PDFs and macOS metadata are not source.
Homesteader Test Documents/
.DS_Store
